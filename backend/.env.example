# FAIR CRM backend environment example
# Copy this file to backend/.env and edit values for your local machine.

# App
APP_ENV=development
APP_DEBUG=true
AUTH_ENABLED=false

# Database - recommended local setup
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fair_crm
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_ALLOW_EMPTY_PASSWORD=false

# Optional: full SQLAlchemy URL override.
# If DATABASE_URL is set, DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD are ignored.
# DATABASE_URL=mysql+pymysql://root:your_mysql_password_here@localhost:3306/fair_crm?charset=utf8mb4
